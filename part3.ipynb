        "pure_cf_txt = \"clustering/reports/SVDKMeans/svd200_k55_ninit10_maxiter300/evaluation_metrics_svd200_kmeans_55.txt\"\n",
        "\n",
        "if os.path.exists(pure_cf_txt) and os.path.exists(hybrid_txt):\n",
