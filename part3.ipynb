        "from sklearn.feature_extraction.text import TfidfVectorizer\n",
        "tfidf_cache_dir = \"data/tfidf_cache\"\n",
        "tfidf_matrix, unique_texts, vectorizer = load_tfidf_matrix(tfidf_cache_dir, df, TfidfVectorizer)"
